model Product {
  id                 String      @id @default(uuid())
  medicine_name      String
  generic_name       String
  mrp                Float
  b2b_discount_price Float
  stock_status       String      // "IN_STOCK" or "OUT_OF_STOCK"
  current_stock      Int         @default(0)
  image_url          String
