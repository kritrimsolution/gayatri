  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id            String @id @default(uuid())
  name          String
  email         String @unique
  password_hash String
  role          String @default("STAFF") // OWNER or STAFF
}

